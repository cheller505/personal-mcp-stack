# Copy to .env and fill in your values. Only set what you need — services
# you don't run can be left unset.

# Microsoft Azure app (shared between email-mcp and onenote-mcp).
# Register at https://portal.azure.com — see README "Credentials at a glance".
EMAIL_MCP_CLIENT_ID=
EMAIL_MCP_TENANT_ID=
ONENOTE_MCP_CLIENT_ID=
ONENOTE_MCP_TENANT_ID=

# Host-side port mappings. Change these if running side-by-side with a
# systemd install (e.g. for testing) or if these ports are in use.
EMAIL_MCP_HOST_PORT=8765
CLICKUP_MCP_HOST_PORT=8767
GRANOLA_MCP_HOST_PORT=8768
ONENOTE_MCP_HOST_PORT=8769
SLACK_MCP_HOST_PORT=8770
OLLAMA_HOST_PORT=11434
CHAT_MCP_HOST_PORT=8082
